# Copy this file to .env and fill in the values.

# GitHub Personal Access Token — raises the repo-scraping rate limit to 5,000/hr.
# Generate at: github.com/settings/tokens (no scopes needed for public repos).
GITHUB_TOKEN=

# Anthropic API key — used by result.ts to score the interview.
# Get one at: console.anthropic.com
CLAUDE_API_KEY=

# OpenAI API key — used for the realtime voice interview (SDP + sideband).
# Get one at: platform.openai.com
OPENAI_KEY=

# Postgres connection string for Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_interviewer"
